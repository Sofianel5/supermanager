{
  "name": "supermanager-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.2.17",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "build": "bun build --compile --bytecode --outfile .build/supermanager-server ./src/main.ts",
    "build:worker": "bun build --compile --bytecode --outfile .build/supermanager-worker ./src/worker-main.ts",
    "start": "./.build/supermanager-server",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/pg": "^8.20.0",
    "bun-types": "^1.2.17",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@better-auth/api-key": "1.6.2",
    "@supermanager/common": "file:../common",
    "@elysiajs/cors": "^1.4.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-auth": "1.6.2",
    "elysia": "^1.4.28",
    "kysely": "^0.28.16",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  }
}
