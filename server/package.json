{
  "name": "supermanager-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.2.17",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "build": "bun build ./src/main.ts --outdir .build --target bun",
    "start": "bun run .build/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/pg": "^8.15.5",
    "bun-types": "^1.2.17",
    "typescript": "^5.9.3"
  }
}
